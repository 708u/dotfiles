{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "allowedTools": [
    "Bash",
    "Edit",
    "Glob",
    "Grep",
    "Read",
    "WebFetch",
    "WebSearch",
    "Write"
  ],
  "autoUpdatesChannel": "latest",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "deepwiki",
    "playwright"
  ],
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "gopls-remote@gopls-remote": true,
    "hookify@claude-code-plugins": false,
    "plugin-dev@claude-code-plugins": true,
    "plugin-dev@claude-plugins-official": true,
    "security-guidance@claude-code-plugins": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "twig@twig-plugins": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "97",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "extraKnownMarketplaces": {
    "gopls-remote": {
      "source": {
        "path": "/Users/708u/ghq/github.com/708u/dotfiles/.config/claude/plugins/gopls-remote",
        "source": "directory"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754033029966
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "afplay /System/Library/Sounds/Glass.aiff",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "jq -r '.tool_input.file_path | select(endswith(\".js\") or endswith(\".ts\") or endswith(\".jsx\") or endswith(\".tsx\"))' | xargs -r npx prettier --write",
            "type": "command"
          },
          {
            "command": "jq -r '.tool_input.file_path | select(endswith(\".go\"))' | xargs -r golangci-lint fmt",
            "type": "command"
          },
          {
            "command": "jq -r '.tool_input.file_path | select(endswith(\".md\"))' | xargs -r markdownlint-cli2 --fix",
            "type": "command"
          },
          {
            "command": "jq -r '.tool_input.file_path | select(endswith(\".tf\") or endswith(\".tftest.hcl\"))' | xargs -r terraform fmt",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreCompact\",\"additionalContext\":\"IMPORTANT: Before compaction, you MUST use the Skill tool to invoke /export-session to save the current session context. Do this immediately.\"}}'",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "afplay /System/Library/Sounds/Submarine.aiff",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "cctidy --unsafe",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "language": "常に丁寧な言葉づかいにする",
  "permissions": {
    "allow": [
      "Bash(code:*)",
      "Bash(cp:*)",
      "Bash(find:*)",
      "Bash(gh pr create:*)",
      "Bash(gh run view:*)",
      "Bash(gh:*)",
      "Bash(git add:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(pnpm --version:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm biome lint:*)",
      "Bash(pnpm install:*)",
      "Bash(popd:*)",
      "Bash(pushd:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(tree:*)",
      "Bash(twig add:*)",
      "Bash(twig list:*)",
      "Skill(figma:implement-design)",
      "Skill(frontend-design:frontend-design)",
      "WebFetch(domain:biomejs.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch"
    ],
    "deny": [
      "NotebookEdit"
    ]
  },
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  }
}
