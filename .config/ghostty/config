command = /bin/zsh
font-family = HackGen35Nerd
font-codepoint-map = U+3000-9FFF=HackGen35Nerd

cursor-style = block
cursor-style-blink = true
cursor-color = #ffe066
selection-background = #264f78
selection-foreground = cell-foreground
shell-integration-features = no-cursor

keybind = super+left_bracket=goto_split:left
keybind = super+right_bracket=goto_split:right
